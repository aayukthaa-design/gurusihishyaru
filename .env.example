# WhatsApp click-to-chat configuration
# Full phone number in international format (country code + number, no spaces or symbols).
VITE_WHATSAPP_PHONE=+919876543200
VITE_WHATSAPP_BUSINESS_NAME=Guru Shishyaru Tutorials

# --- Backend (server/server.js) ---

# Required in production. Generate with: openssl rand -base64 32
# The server refuses to start with NODE_ENV=production unless this is set to a
# real secret (it will not silently fall back to the insecure development default).
JWT_SECRET=

# Comma-separated list of allowed frontend origins, e.g. https://app.example.com,https://admin.example.com
# In production, requests from origins not on this list are rejected.
CORS_ORIGIN=

# Set to "production" when deploying (enables the JWT_SECRET guard above and
# tightens CORS defaults). Leave unset for local development.
NODE_ENV=

PORT=4000
